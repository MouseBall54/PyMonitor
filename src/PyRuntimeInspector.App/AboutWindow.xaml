<Window x:Class="PyRuntimeInspector.App.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About PyMonitor"
        Icon="Assets/app-icon.ico"
        Width="640"
        Height="540"
        MinWidth="520"
        MinHeight="460"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        ResizeMode="CanResizeWithGrip"
        Background="#F6F8FB"
        FontFamily="Segoe UI"
        Foreground="#172033"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        AutomationProperties.Name="About PyMonitor">
    <Window.Resources>
        <SolidColorBrush x:Key="AboutMutedText" Color="#5F6B7A" />
        <SolidColorBrush x:Key="AboutBorder" Color="#D7DEE8" />
        <SolidColorBrush x:Key="AboutAccent" Color="#2563EB" />
        <Style x:Key="MetadataLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource AboutMutedText}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>
        <Style x:Key="MetadataValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#172033" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style x:Key="CloseButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AboutAccent}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#1D4ED8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="22,8" />
            <Setter Property="MinWidth" Value="96" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#1D4ED8" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#93C5FD" />
                                <Setter TargetName="Chrome" Property="BorderThickness" Value="2" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Chrome" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="176" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#0F3D73" Offset="0" />
                    <GradientStop Color="#2563EB" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>
            <Grid Margin="32,26">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="104" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Width="84"
                        Height="84"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        CornerRadius="18"
                        Background="#F8FAFC"
                        BorderBrush="#66FFFFFF"
                        BorderThickness="1"
                        AutomationProperties.Name="PyMonitor application icon">
                    <Image Source="Assets/app-icon.ico" Width="66" Height="66" Stretch="Uniform" />
                </Border>
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="2,0,0,0">
                    <TextBlock Text="PyMonitor" Foreground="White" FontSize="32" FontWeight="SemiBold" />
                    <TextBlock Text="Python Runtime Inspector" Foreground="#DCEAFE" FontSize="15" Margin="0,3,0,10" />
                    <Border HorizontalAlignment="Left" Background="#26FFFFFF" CornerRadius="12" Padding="10,4">
                        <TextBlock Text="Version 26.7.11" Foreground="White" FontSize="12" FontWeight="SemiBold" />
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="32,26,32,18">
                <TextBlock Text="A read-only runtime inspector for exploring variables, object structures, classes, arrays, and memory in a connected CPython process."
                           Foreground="{StaticResource AboutMutedText}"
                           FontSize="14"
                           LineHeight="21"
                           TextWrapping="Wrap" />

                <Border Background="White"
                        BorderBrush="{StaticResource AboutBorder}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="18"
                        Margin="0,20,0,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="24" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="18" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Grid.Column="0">
                            <TextBlock Text="DEVELOPER" Style="{StaticResource MetadataLabel}" />
                            <TextBlock Text="Developed by 박영문" Style="{StaticResource MetadataValue}" />
                        </StackPanel>
                        <StackPanel Grid.Row="0" Grid.Column="2">
                            <TextBlock Text="PLATFORM" Style="{StaticResource MetadataLabel}" />
                            <TextBlock Text="Windows 10/11 x64" Style="{StaticResource MetadataValue}" />
                        </StackPanel>
                        <StackPanel Grid.Row="2" Grid.Column="0">
                            <TextBlock Text="PYTHON SUPPORT" Style="{StaticResource MetadataLabel}" />
                            <TextBlock Text="CPython 3.10–3.14" Style="{StaticResource MetadataValue}" />
                        </StackPanel>
                        <StackPanel Grid.Row="2" Grid.Column="2">
                            <TextBlock Text="INSPECTION MODE" Style="{StaticResource MetadataLabel}" />
                            <TextBlock Text="Read-only" Style="{StaticResource MetadataValue}" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Background="#EFF6FF" BorderBrush="#BFDBFE" BorderThickness="1" CornerRadius="8" Padding="16,13">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Background="#DBEAFE" CornerRadius="12" Padding="9,4" VerticalAlignment="Top">
                            <TextBlock Text="READ-ONLY" Foreground="#1D4ED8" FontSize="11" FontWeight="Bold" />
                        </Border>
                        <TextBlock Grid.Column="1"
                                   Margin="12,1,0,0"
                                   Text="PyMonitor observes runtime state through bounded, safe inspection and does not modify target variables."
                                   Foreground="#334155"
                                   FontSize="13"
                                   LineHeight="19"
                                   TextWrapping="Wrap" />
                    </Grid>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2" Background="White" BorderBrush="{StaticResource AboutBorder}" BorderThickness="0,1,0,0" Padding="24,14">
            <Grid>
                <TextBlock Text="PyMonitor 26.7.11"
                           Foreground="{StaticResource AboutMutedText}"
                           FontSize="12"
                           VerticalAlignment="Center" />
                <Button Content="Close"
                        HorizontalAlignment="Right"
                        IsDefault="True"
                        IsCancel="True"
                        Style="{StaticResource CloseButtonStyle}"
                        AutomationProperties.Name="Close About PyMonitor"
                        Click="Close_Click" />
            </Grid>
        </Border>
    </Grid>
</Window>
