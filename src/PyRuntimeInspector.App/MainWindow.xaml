<Window x:Class="PyRuntimeInspector.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:PyRuntimeInspector.App.Controls"
        xmlns:vm="clr-namespace:PyRuntimeInspector.App.ViewModels"
        Title="PyRuntime Inspector" Width="1500" Height="920" MinWidth="1180" MinHeight="720"
        Background="{StaticResource WindowBackground}" Foreground="{StaticResource PrimaryText}"
        Closed="Window_Closed">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="105" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource PanelBackground}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="10,8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="PyRuntime Inspector" FontSize="19" FontWeight="SemiBold" Margin="0,0,18,0" VerticalAlignment="Center" />
                    <TextBlock Text="Process" Foreground="{StaticResource SecondaryText}" VerticalAlignment="Center" Margin="0,0,5,0" />
                    <ComboBox Width="190" ItemsSource="{Binding Processes}" SelectedItem="{Binding SelectedProcess}" DisplayMemberPath="DisplayName" ToolTip="Optional PID validation. Leave empty to accept any cooperative target." />
                    <Button Content="↻" Command="{Binding RefreshProcessesCommand}" ToolTip="Refresh Python processes" />
                    <TextBlock Text="PID" Foreground="{StaticResource SecondaryText}" Margin="12,0,4,0" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding TargetPid, TargetNullValue=—}" FontFamily="Cascadia Mono" VerticalAlignment="Center" />
                    <TextBlock Text="Python" Foreground="{StaticResource SecondaryText}" Margin="14,0,4,0" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding PythonVersion}" MaxWidth="210" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding Architecture}" Foreground="{StaticResource SecondaryText}" Margin="8,0,12,0" VerticalAlignment="Center" />
                    <Button Content="Attach" Command="{Binding AttachCommand}" Background="#1F6FEB" BorderBrush="#388BFD" FontWeight="SemiBold" />
                    <Button Content="Launch" Command="{Binding LaunchCommand}" Background="#238636" BorderBrush="#2EA043" FontWeight="SemiBold" />
                    <Button Content="Stop" Command="{Binding StopCommand}" />
                    <Button Content="Restart" Command="{Binding RestartCommand}" />
                    <Button Content="Detach" Command="{Binding DetachCommand}" />
                    <Button Content="Refresh" Command="{Binding RefreshCommand}" />
                </StackPanel>
                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,7,0,0" VerticalAlignment="Center">
                    <TextBlock Text="Port" Foreground="{StaticResource SecondaryText}" VerticalAlignment="Center" />
                    <TextBox Text="{Binding PortText, UpdateSourceTrigger=PropertyChanged}" Width="70" Margin="5,0,10,0" />
                    <TextBlock Text="Token" Foreground="{StaticResource SecondaryText}" VerticalAlignment="Center" />
                    <TextBox Text="{Binding Token, UpdateSourceTrigger=PropertyChanged}" Width="260" FontFamily="Cascadia Mono" Margin="5,0,2,0" />
                    <Button Content="Copy environment" Command="{Binding CopyEnvironmentCommand}" ToolTip="Copy the cooperative target environment to the clipboard." />
                    <Ellipse Width="9" Height="9" Margin="14,0,6,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="#6E7681" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                        <Setter Property="Fill" Value="{StaticResource SuccessBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Text="{Binding Status}" VerticalAlignment="Center" />
                    <Border Background="#173B2A" CornerRadius="3" Padding="7,2" Margin="14,0,0,0">
                        <TextBlock Text="Safe Mode ON" Foreground="#7EE787" FontWeight="SemiBold" />
                    </Border>
                    <TextBlock Text="Refresh" Foreground="{StaticResource SecondaryText}" Margin="14,0,4,0" VerticalAlignment="Center" />
                    <ComboBox Width="65" ItemsSource="{Binding RefreshIntervals}" SelectedItem="{Binding RefreshIntervalSeconds}" />
                    <TextBlock Text="s" VerticalAlignment="Center" Margin="3,0,0,0" />
                    <TextBlock Text="Private" Foreground="{StaticResource SecondaryText}" Margin="14,0,4,0" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding PrivateBytes}" VerticalAlignment="Center" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="270" MinWidth="210" />
                <ColumnDefinition Width="5" />
                <ColumnDefinition Width="*" MinWidth="500" />
                <ColumnDefinition Width="5" />
                <ColumnDefinition Width="310" MinWidth="260" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{StaticResource PanelBackground}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="RUNTIME TREE" Foreground="{StaticResource SecondaryText}" FontSize="11" FontWeight="SemiBold" Margin="12,10,8,8" />
                    <TreeView ItemsSource="{Binding RuntimeRoots}" SelectedItemChanged="RuntimeTree_SelectedItemChanged" Background="Transparent" BorderThickness="0" Padding="5">
                        <TreeView.Resources>
                            <HierarchicalDataTemplate DataType="{x:Type vm:RuntimeTreeNode}" ItemsSource="{Binding Children}">
                                <TextBlock Text="{Binding Label}" ToolTip="{Binding Label}" TextTrimming="CharacterEllipsis" />
                            </HierarchicalDataTemplate>
                        </TreeView.Resources>
                    </TreeView>
                </DockPanel>
            </Border>
            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" Background="{StaticResource BorderBrush}" />

            <Border Grid.Column="2" Background="{StaticResource PanelBackground}">
                <TabControl>
                    <TabItem Header="Variables">
                        <Grid Margin="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <DockPanel Margin="0,0,0,7">
                                <TextBlock DockPanel.Dock="Left" Text="{Binding Breadcrumb}" FontWeight="SemiBold" VerticalAlignment="Center" />
                                <TextBox DockPanel.Dock="Right" Width="220" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" ToolTip="Search name, type, or preview" />
                            </DockPanel>
                            <DataGrid Grid.Row="1" ItemsSource="{Binding FilteredVariables}" SelectedItem="{Binding SelectedVariable}" AutoGenerateColumns="False"
                                      IsReadOnly="True" SelectionMode="Single" EnableRowVirtualization="True" EnableColumnVirtualization="True"
                                      VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling" ScrollViewer.CanContentScroll="True">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="160" />
                                    <DataGridTextColumn Header="Scope" Binding="{Binding Scope}" Width="75" />
                                    <DataGridTextColumn Header="Type" Binding="{Binding TypeName}" Width="120" />
                                    <DataGridTextColumn Header="Safe Preview" Binding="{Binding SafePreview}" Width="2*" />
                                    <DataGridTextColumn Header="Shape" Binding="{Binding Shape}" Width="120" />
                                    <DataGridTextColumn Header="DType" Binding="{Binding DType}" Width="80" />
                                    <DataGridTextColumn Header="Shallow" Binding="{Binding ShallowSize}" Width="85" />
                                    <DataGridTextColumn Header="Payload" Binding="{Binding PayloadSize}" Width="90" />
                                    <DataGridTextColumn Header="Address" Binding="{Binding Address}" Width="140" />
                                    <DataGridCheckBoxColumn Header="Changed" Binding="{Binding Changed}" Width="65" />
                                    <DataGridCheckBoxColumn Header="Expand" Binding="{Binding Expandable}" Width="60" />
                                </DataGrid.Columns>
                            </DataGrid>
                            <DockPanel Grid.Row="2" Margin="0,7,0,0">
                                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                                    <Button Content="Previous" Command="{Binding PreviousPageCommand}" />
                                    <TextBlock Text="{Binding PageLabel}" Margin="8,0" VerticalAlignment="Center" />
                                    <Button Content="Next" Command="{Binding NextPageCommand}" />
                                </StackPanel>
                            </DockPanel>
                        </Grid>
                    </TabItem>
                    <TabItem Header="Object Inspector">
                        <DataGrid Margin="8" ItemsSource="{Binding ObjectChildren}" AutoGenerateColumns="False" IsReadOnly="True"
                                  EnableRowVirtualization="True" VirtualizingPanel.VirtualizationMode="Recycling">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="180" />
                                <DataGridTextColumn Header="Origin" Binding="{Binding Origin}" Width="120" />
                                <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="140" />
                                <DataGridTextColumn Header="Safe Preview" Binding="{Binding Preview}" Width="*" />
                                <DataGridTextColumn Header="Address" Binding="{Binding Address}" Width="150" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </TabItem>
                    <TabItem Header="Managed Launch">
                        <Grid Margin="10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="8" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.2*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid Grid.Column="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="105" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Python" VerticalAlignment="Center" Foreground="{StaticResource SecondaryText}" />
                                    <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding PythonExecutable, UpdateSourceTrigger=PropertyChanged}" />
                                    <Button Grid.Row="0" Grid.Column="2" Content="Browse…" Command="{Binding BrowsePythonCommand}" />
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Script" VerticalAlignment="Center" Foreground="{StaticResource SecondaryText}" />
                                    <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding ScriptPath, UpdateSourceTrigger=PropertyChanged}" />
                                    <Button Grid.Row="1" Grid.Column="2" Content="Browse…" Command="{Binding BrowseScriptCommand}" />
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Arguments" VerticalAlignment="Center" Foreground="{StaticResource SecondaryText}" />
                                    <TextBox Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" Text="{Binding ScriptArguments, UpdateSourceTrigger=PropertyChanged}" ToolTip="Windows command-line quoting is supported." />
                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Working directory" VerticalAlignment="Center" Foreground="{StaticResource SecondaryText}" />
                                    <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding WorkingDirectory, UpdateSourceTrigger=PropertyChanged}" />
                                    <Button Grid.Row="3" Grid.Column="2" Content="Browse…" Command="{Binding BrowseWorkingDirectoryCommand}" />
                                    <StackPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="3" Orientation="Horizontal" Margin="0,7,0,0">
                                        <Button Content="Launch" Command="{Binding LaunchCommand}" Background="#238636" BorderBrush="#2EA043" />
                                        <Button Content="Stop" Command="{Binding StopCommand}" />
                                        <Button Content="Restart" Command="{Binding RestartCommand}" />
                                        <TextBlock Text="Status" Foreground="{StaticResource SecondaryText}" Margin="12,0,4,0" VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding ManagedStatus}" VerticalAlignment="Center" />
                                        <TextBlock Text="PID" Foreground="{StaticResource SecondaryText}" Margin="12,0,4,0" VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding ManagedProcessId, TargetNullValue=—}" VerticalAlignment="Center" FontFamily="Cascadia Mono" />
                                        <TextBlock Text="Exit" Foreground="{StaticResource SecondaryText}" Margin="12,0,4,0" VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding ManagedExitCode}" VerticalAlignment="Center" FontFamily="Cascadia Mono" />
                                    </StackPanel>
                                </Grid>
                                <Grid Grid.Column="2">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="110" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Text="Environment overrides" Foreground="{StaticResource SecondaryText}" Margin="0,0,0,4" />
                                    <DataGrid Grid.Row="1" ItemsSource="{Binding LaunchEnvironment}" SelectedItem="{Binding SelectedEnvironmentVariable}"
                                              AutoGenerateColumns="False" CanUserAddRows="False" EnableRowVirtualization="True">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Name" Binding="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Width="*" />
                                            <DataGridTextColumn Header="Value" Binding="{Binding Value, UpdateSourceTrigger=PropertyChanged}" Width="2*" />
                                        </DataGrid.Columns>
                                    </DataGrid>
                                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                                        <Button Content="Add" Command="{Binding AddEnvironmentCommand}" />
                                        <Button Content="Remove" Command="{Binding RemoveEnvironmentCommand}" />
                                    </StackPanel>
                                </Grid>
                            </Grid>
                            <Border Grid.Row="2" Background="#05070A" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                                <DockPanel>
                                    <Grid DockPanel.Dock="Top" Margin="8,5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="PROCESS OUTPUT" Foreground="{StaticResource SecondaryText}" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center" />
                                        <Button Grid.Column="1" Content="Clear" Command="{Binding ClearOutputCommand}" />
                                    </Grid>
                                    <ListBox x:Name="LaunchOutputList" ItemsSource="{Binding LaunchOutput}" Background="Transparent" BorderThickness="0"
                                             FontFamily="Cascadia Mono" FontSize="12" VirtualizingPanel.IsVirtualizing="True"
                                             VirtualizingPanel.VirtualizationMode="Recycling" ScrollViewer.CanContentScroll="True">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Display}" TextWrapping="NoWrap">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="#C9D1D9" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Kind}" Value="StandardError">
                                                                    <Setter Property="Foreground" Value="#FF7B72" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </DockPanel>
                            </Border>
                        </Grid>
                    </TabItem>
                    <TabItem Header="Class &amp; Methods">
                        <DataGrid Margin="8" ItemsSource="{Binding ClassMembers}" AutoGenerateColumns="False" IsReadOnly="True"
                                  EnableRowVirtualization="True" VirtualizingPanel.VirtualizationMode="Recycling">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="180" />
                                <DataGridTextColumn Header="Kind" Binding="{Binding Kind}" Width="130" />
                                <DataGridTextColumn Header="Declared by" Binding="{Binding DeclaredBy}" Width="150" />
                                <DataGridTextColumn Header="Signature" Binding="{Binding Signature}" Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </TabItem>
                    <TabItem Header="Array / Image">
                        <Grid Margin="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="180" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="190" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Text="VIEW" Foreground="{StaticResource SecondaryText}" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,7" />
                                <TextBlock Text="Layout" />
                                <ComboBox ItemsSource="{Binding Layouts}" SelectedItem="{Binding ArrayLayout}" />
                                <TextBlock Text="Color order" Margin="0,8,0,0" />
                                <ComboBox ItemsSource="{Binding ColorOrders}" SelectedItem="{Binding ColorOrder}" />
                                <TextBlock Text="Channels" Margin="0,8,0,2" />
                                <StackPanel Orientation="Horizontal">
                                    <CheckBox Content="R" IsChecked="{Binding ChannelR}" Margin="0,0,10,0" />
                                    <CheckBox Content="G" IsChecked="{Binding ChannelG}" Margin="0,0,10,0" />
                                    <CheckBox Content="B" IsChecked="{Binding ChannelB}" />
                                </StackPanel>
                                <TextBlock Text="Slice axis" Margin="0,8,0,0" />
                                <ComboBox ItemsSource="{Binding SliceAxes}" SelectedItem="{Binding SliceAxis}" />
                                <TextBlock Text="Slice index" Margin="0,8,0,0" />
                                <Slider Minimum="0" Maximum="{Binding SliceMaximum}" Value="{Binding SliceIndex}" TickFrequency="1" IsSnapToTickEnabled="True" />
                                <TextBlock Text="{Binding SliceIndex}" HorizontalAlignment="Right" />
                                <Button Content="Apply preview" Command="{Binding ReloadPreviewCommand}" Margin="0,10,0,0" />
                                <Separator Margin="0,10" />
                                <Button Content="Fit" Command="{Binding FitCommand}" />
                                <Button Content="1:1" Command="{Binding OneToOneCommand}" />
                                <TextBlock Text="Zoom" Margin="0,8,0,0" />
                                <Slider Minimum="0.05" Maximum="32" Value="{Binding Zoom}" />
                                <TextBlock Text="{Binding Zoom, StringFormat={}{0:F2}×}" HorizontalAlignment="Right" />
                                <TextBlock Text="Histogram is scheduled for the advanced viewer phase." Foreground="{StaticResource SecondaryText}" TextWrapping="Wrap" Margin="0,12,0,0" />
                            </StackPanel>
                            <Border Grid.Column="1" Background="#05070A" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                                <ScrollViewer x:Name="ImageViewerScroll" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                                              SizeChanged="ImageViewerScroll_SizeChanged" PreviewMouseWheel="ImageViewerScroll_PreviewMouseWheel"
                                              PreviewMouseRightButtonDown="ImageViewerScroll_RightButtonDown"
                                              PreviewMouseRightButtonUp="ImageViewerScroll_RightButtonUp"
                                              PreviewMouseMove="ImageViewerScroll_PreviewMouseMove">
                                    <Grid Width="{Binding ImageDisplayWidth}" Height="{Binding ImageDisplayHeight}">
                                        <Image x:Name="PreviewImage" Source="{Binding ArrayPreview}" Stretch="Fill"
                                               RenderOptions.BitmapScalingMode="NearestNeighbor"
                                               MouseMove="PreviewImage_MouseMove" MouseLeftButtonUp="PreviewImage_MouseLeftButtonUp" />
                                        <controls:PixelGridOverlay Zoom="{Binding Zoom}" IsHitTestVisible="False" />
                                    </Grid>
                                </ScrollViewer>
                            </Border>
                            <StackPanel Grid.Column="2" Margin="10,0,0,0">
                                <TextBlock Text="PIXEL" Foreground="{StaticResource SecondaryText}" FontSize="11" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding CursorCoordinate}" FontFamily="Cascadia Mono" Margin="0,7,0,10" />
                                <TextBlock Text="Raw value" Foreground="{StaticResource SecondaryText}" />
                                <TextBlock Text="{Binding RawPixelValue}" FontFamily="Cascadia Mono" TextWrapping="Wrap" Margin="0,2,0,9" />
                                <TextBlock Text="Displayed value" Foreground="{StaticResource SecondaryText}" />
                                <TextBlock Text="{Binding DisplayPixelValue}" FontFamily="Cascadia Mono" TextWrapping="Wrap" Margin="0,2,0,9" />
                                <TextBlock Text="Normalization" Foreground="{StaticResource SecondaryText}" />
                                <TextBlock Text="{Binding Normalization}" TextWrapping="Wrap" Margin="0,2,0,9" />
                                <TextBlock Text="Preview" Foreground="{StaticResource SecondaryText}" />
                                <TextBlock FontFamily="Cascadia Mono">
                                    <Run Text="{Binding PreviewWidth, Mode=OneWay}" /><Run Text=" × " /><Run Text="{Binding PreviewHeight, Mode=OneWay}" />
                                </TextBlock>
                                <TextBlock Text="Click a pixel to request its exact source value." Foreground="{StaticResource SecondaryText}" TextWrapping="Wrap" Margin="0,12,0,0" />
                            </StackPanel>
                        </Grid>
                    </TabItem>
                    <TabItem Header="Memory">
                        <StackPanel Margin="24">
                            <TextBlock Text="OS process memory" FontSize="17" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding PrivateBytes, StringFormat=Private bytes: {0}}" Margin="0,8,0,0" />
                            <TextBlock Text="tracemalloc controls and snapshot diff are Phase 4." Foreground="{StaticResource SecondaryText}" Margin="0,12,0,0" />
                        </StackPanel>
                    </TabItem>
                    <TabItem Header="Execution Events">
                        <TextBlock Text="Bounded sys.monitoring events are Phase 6." Foreground="{StaticResource SecondaryText}" Margin="24" />
                    </TabItem>
                </TabControl>
            </Border>
            <GridSplitter Grid.Column="3" Width="5" HorizontalAlignment="Stretch" Background="{StaticResource BorderBrush}" />

            <Border Grid.Column="4" Background="{StaticResource PanelBackground}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1,0,0,0" Padding="12">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="DETAILS" Foreground="{StaticResource SecondaryText}" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,10" />
                        <TextBlock Text="Type" Foreground="{StaticResource SecondaryText}" />
                        <TextBlock Text="{Binding SelectedType}" FontWeight="SemiBold" Margin="0,2,0,9" />
                        <TextBlock Text="Module" Foreground="{StaticResource SecondaryText}" />
                        <TextBlock Text="{Binding SelectedModule}" Margin="0,2,0,9" />
                        <TextBlock Text="Qualified name" Foreground="{StaticResource SecondaryText}" />
                        <TextBlock Text="{Binding SelectedQualifiedName}" TextWrapping="Wrap" Margin="0,2,0,9" />
                        <TextBlock Text="Object address" Foreground="{StaticResource SecondaryText}" />
                        <TextBlock Text="{Binding SelectedAddress}" FontFamily="Cascadia Mono" Margin="0,2,0,9" />
                        <TextBlock Text="Shallow size" Foreground="{StaticResource SecondaryText}" />
                        <TextBlock Text="{Binding SelectedShallowSize}" Margin="0,2,0,9" />
                        <TextBlock Text="Payload size" Foreground="{StaticResource SecondaryText}" />
                        <TextBlock Text="{Binding SelectedPayloadSize}" Margin="0,2,0,9" />
                        <Separator Margin="0,5,0,10" />
                        <TextBlock Text="ARRAY" Foreground="{StaticResource SecondaryText}" FontSize="11" FontWeight="SemiBold" />
                        <TextBlock Text="Shape" Foreground="{StaticResource SecondaryText}" Margin="0,8,0,0" />
                        <TextBlock Text="{Binding ArrayShape}" FontFamily="Cascadia Mono" />
                        <TextBlock Text="DType" Foreground="{StaticResource SecondaryText}" Margin="0,8,0,0" />
                        <TextBlock Text="{Binding ArrayDType}" />
                        <TextBlock Text="Strides" Foreground="{StaticResource SecondaryText}" Margin="0,8,0,0" />
                        <TextBlock Text="{Binding ArrayStrides}" FontFamily="Cascadia Mono" />
                        <TextBlock Text="Data address" Foreground="{StaticResource SecondaryText}" Margin="0,8,0,0" />
                        <TextBlock Text="{Binding ArrayDataAddress}" FontFamily="Cascadia Mono" />
                        <TextBlock Text="Owner" Foreground="{StaticResource SecondaryText}" Margin="0,8,0,0" />
                        <TextBlock Text="{Binding ArrayOwner}" />
                        <TextBlock Text="Layout confidence" Foreground="{StaticResource SecondaryText}" Margin="0,8,0,0" />
                        <TextBlock Text="{Binding LayoutConfidence}" />
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="#0B0F14" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0" Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="DIAGNOSTICS" Foreground="{StaticResource SecondaryText}" FontSize="11" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding Status}" Margin="0,5,0,0" />
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="#FF7B72" TextWrapping="Wrap" Margin="0,3,12,0" />
                </StackPanel>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="REQUEST" Foreground="{StaticResource SecondaryText}" FontSize="11" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding LastLatency, StringFormat=Latency  {0}}" Margin="0,5,0,0" />
                    <TextBlock Text="Async socket calls only" Foreground="{StaticResource SecondaryText}" Margin="0,3,0,0" />
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="AGENT" Foreground="{StaticResource SecondaryText}" FontSize="11" FontWeight="SemiBold" />
                    <TextBlock Text="Bounded handles • read-only" Margin="0,5,0,0" />
                    <TextBlock Text="Snapshots may be stale" Foreground="{StaticResource WarningBrush}" Margin="0,3,0,0" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
